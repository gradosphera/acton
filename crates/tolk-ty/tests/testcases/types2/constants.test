========================================================================
Constant declaration with type hint
========================================================================
const FOO: int
//!   ^ int
    = 10;
//!   ^ int

fun main() {
    val a = FOO;
    //! ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Constant declaration with struct type hint
========================================================================
struct Foo {
    value: int,
}

const FOO: Foo
//!   ^ Foo
    = {
//!   ^ Foo
          value: 10
//!       ^ int
      };

fun main() {
    val a = FOO;
    //! ^ Foo
}
------------------------------------------------------------------------
ok

========================================================================
Imported constant without explicit type hint
========================================================================
import "deps"

fun main() {
    val a = DEFAULT_TRANSFER_MSG_VALUE;
    //! ^ int
}
---FILE:deps.tolk
const DEFAULT_TRANSFER_MSG_VALUE = 300000000
------------------------------------------------------------------------
ok

