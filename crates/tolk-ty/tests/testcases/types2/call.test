ok

========================================================================
Function function call with short instance expression
========================================================================
struct Foo {
    value: int,
}

fun getCallable(): (Foo) -> int {}

fun main() {
    val foo =
//!     ^ int
        getCallable()({
//!                   ^ Foo
            value: 10,
//!         ^ int
        });
}
------------------------------------------------------------------------
ok

