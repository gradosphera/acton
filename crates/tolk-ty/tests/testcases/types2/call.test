ok

========================================================================
Call variable with function name
========================================================================
fun foo(): int | bool {}

fun main() {
    val a = foo;
    //! ^ () -> int | bool

    val res = a();
    //! ^ int | bool
}
------------------------------------------------------------------------
ok

========================================================================
Call variable with function name and infer short struct instance
========================================================================
struct Foo {
    value: int,
}

fun foo(foo: Foo): int | bool {}

fun main() {
    val a = foo;
    //! ^ (Foo) -> int | bool

    val res =
    //! ^ int | bool
        a({
//!       ^ Foo
            value: 10,
//!         ^ int
        });
}
------------------------------------------------------------------------
ok

