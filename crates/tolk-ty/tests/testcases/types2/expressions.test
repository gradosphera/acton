========================================================================
Paren expression
========================================================================
fun foo(): int | bool {}

fun main() {
    val a = (foo());
    //! ^ int | bool
    val a = ((((((((10))))))));
    //! ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Array literal expression
========================================================================
fun main() {
    val a = [1, true, ""];
//!     ^ array<int | bool | string>
}
------------------------------------------------------------------------
ok

========================================================================
Tuple literal expression with tuple hint
========================================================================
fun main() {
    val a: [int, bool] = [1, true];
//!     ^ [int, bool]
}
------------------------------------------------------------------------
ok

========================================================================
Array literal expression with explicit type
========================================================================
fun main() {
    val a = array<int>[1, 2];
//!     ^ array<int>
}
------------------------------------------------------------------------
ok

========================================================================
Empty array literal expression
========================================================================
fun main() {
    val a = [];
//!     ^ array<unknown>
}
------------------------------------------------------------------------
ok

========================================================================
Tensor literal type inference
========================================================================
fun main() {
    val data = (1, true, "hello");
    //! ^ (int, bool, string)
}
------------------------------------------------------------------------
ok

========================================================================
Complex tensor and tuple literal type inference
========================================================================
fun main() {
    val data = (1, [1, [1, true, "hello"], (1, [1, [1, true, "hello"], "hello"], "hello")], "hello");
    //! ^ (int, array<int | array<int | bool | string> | (int, array<int | array<int | bool | string> | string>, string)>, string)
}
------------------------------------------------------------------------
ok

========================================================================
Null-coalescing expression
========================================================================
fun main(v: int?, fallback: int) {
    val a = v ?? fallback;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Null-coalescing expression with non-null lhs
========================================================================
fun main(v: int, fallback: int) {
    val a = v ?? fallback;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
As cast expression
========================================================================
fun main() {
    val a = true as int;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Not null expression
========================================================================
fun main(arg: int | null) {
    val a = arg!;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Not null expression 2
========================================================================
fun main(arg: int | slice | bool | null) {
    val a = arg!;
//!     ^ int | slice | bool
}
------------------------------------------------------------------------
ok

========================================================================
! operator
========================================================================
fun main(arg: bool) {
    val a = !arg;
//!     ^ bool
}
------------------------------------------------------------------------
ok

========================================================================
- operator
========================================================================
fun main(arg: int) {
    val a = -arg;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
+ operator
========================================================================
fun main(arg: int) {
    val a = -arg;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
~ operator
========================================================================
fun main(arg: int) {
    val a = -arg;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Assignment
========================================================================
fun main(arg: int) {
    val a = arg = 10;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Set assignment
========================================================================
fun main(arg: int) {
    val a = arg += 10;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
_ type
========================================================================
fun main(arg: int) {
    _;
//! ^ unknown
}
------------------------------------------------------------------------
ok

========================================================================
Reference to constant
========================================================================
const FOO = 10;

fun main() {
    val data = FOO;
    //! ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Reference to global variable
========================================================================
global foo: int;

fun main() {
    val data = foo;
    //! ^ int
}
------------------------------------------------------------------------
ok
